# Bitbank API credentials
BITBANK_API_KEY=your_api_key_here
BITBANK_API_SECRET=your_api_secret_here

# Discord notification webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here

# Database path (optional, defaults to data/candles.db)
# DB_PATH=data/candles.db

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
